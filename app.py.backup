from flask import Flask, request, jsonify
import logging
from database import get_tenant_by_phone_id
from modules import handle_sales_inquiry, handle_return_exchange_text, handle_defective_product_image

app = Flask(__name__)
logging.basicConfig(level=logging.INFO)
logger = logging.getLogger(__name__)

@app.route('/webhook', methods=['GET'])
def verify_webhook():
    """WhatsApp webhook verification"""
    mode = request.args.get('hub.mode')
    token = request.args.get('hub.verify_token')
    challenge = request.args.get('hub.challenge')
    
    if mode == 'subscribe' and token == 'YOUR_VERIFY_TOKEN':
        logger.info("Webhook verified successfully")
        return challenge, 200
    else:
        return 'Forbidden', 403

@app.route('/webhook', methods=['POST'])
def webhook():
    """WhatsApp mesaj webhook'u"""
    try:
        data = request.get_json()
        logger.info(f"Received webhook: {data}")
        
        # WhatsApp mesaj yapısını parse et
        if not data.get('entry'):
            return jsonify({'status': 'no entry'}), 200
            
        for entry in data['entry']:
            for change in entry.get('changes', []):
                value = change.get('value', {})
                messages = value.get('messages', [])
                
                for message in messages:
                    # Müşteri bilgileri
                    from_number = message.get('from')
                    message_type = message.get('type')
                    
                    # Tenant'ı bul
                    tenant = get_tenant_by_phone_id(from_number)
                    if not tenant:
                        logger.warning(f"Tenant not found for {from_number}")
                        continue
                    
                    # Mesaj tipine göre işle
                    if message_type == 'text':
                        text = message.get('text', {}).get('body', '')
                        response = handle_message_text(tenant, from_number, text)
                        
                    elif message_type == 'image':
                        image_id = message.get('image', {}).get('id')
                        caption = message.get('image', {}).get('caption', '')
                        response = handle_message_image(tenant, from_number, image_id, caption)
                    
                    else:
                        logger.info(f"Unsupported message type: {message_type}")
                        continue
                    
                    # Yanıtı gönder (whatsapp_client kullanarak)
                    logger.info(f"Response: {response}")
        
        return jsonify({'status': 'success'}), 200
        
    except Exception as e:
        logger.error(f"Webhook error: {str(e)}")
        return jsonify({'status': 'error', 'message': str(e)}), 500

def handle_message_text(tenant, customer_phone, text):
    """Metin mesajını işle"""
    text_lower = text.lower()
    
    # İade/değişim keywords
    return_keywords = ['iade', 'değişim', 'iade etmek', 'değiştirmek', 'kusur', 'hatalı']
    if any(keyword in text_lower for keyword in return_keywords):
        return handle_return_exchange_text(tenant, text)
    
    # Satış/ürün sorgusu (default)
    return handle_sales_inquiry(tenant, text)

def handle_message_image(tenant, customer_phone, image_id, caption):
    """Görsel mesajını işle"""
    # Görseli indir ve işle
    # image_data = download_whatsapp_image(image_id)
    
    # Şimdilik caption varsa onu kullan
    if 'kusur' in caption.lower() or 'hatalı' in caption.lower() or 'iade' in caption.lower():
        # return handle_defective_product_image(tenant, image_data, caption)
        return "Görselinizi aldık. İnceleme yapıyoruz."
    
    return "Görselinizi aldık. Teşekkür ederiz!"

if __name__ == '__main__':
    app.run(host='0.0.0.0', port=5001, debug=True)
